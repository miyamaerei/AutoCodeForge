# Docker Compose 环境变量配置文件
# 复制此文件为 .env 并填写实际值

# 数据库密码（至少 8 字符，包含大小写字母、数字和特殊字符）
DB_PASSWORD=YourStrongPassword@123

# JWT 密钥（至少 32 字符）
# 生成方法: openssl rand -base64 32
JWT_KEY=your-jwt-secret-key-at-least-32-characters-long

# 加密密钥（32 字节 Base64）
# 生成方法: openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key-32-bytes-base64
