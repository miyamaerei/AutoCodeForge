<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.10.4" />
    <PackageReference Include="MSTest.TestFramework" Version="3.10.4" />
    <PackageReference Include="Moq" Version="4.20.70" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\AutoCodeForge.Api\AutoCodeForge.Api.csproj" />
    <ProjectReference Include="..\..\src\AutoCodeForge.Application\AutoCodeForge.Application.csproj" />
    <ProjectReference Include="..\..\src\AutoCodeForge.Infrastructure\AutoCodeForge.Infrastructure.csproj" />
    <ProjectReference Include="..\..\src\AutoCodeForge.Core\AutoCodeForge.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- 测试配置文件：复制到输出目录，但不会被 Git 跟踪 -->
    <Content Include="test-configs\azure-devops-config.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>test-configs\azure-devops-config.json</Link>
    </Content>
  </ItemGroup>

</Project>