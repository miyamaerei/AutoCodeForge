{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=autocodeforge.db"
  },
  "Jwt": {
    "Issuer": "AutoCodeForge",
    "Audience": "AutoCodeForge.Client",
    "Key": "CHANGE_ME_IN_PRODUCTION_WITH_AT_LEAST_32_CHARS",
    "ExpireMinutes": 120
  },
  "Encryption": {
    "Key": "CHANGE_ME_IN_PRODUCTION_WITH_A_32_BYTE_BASE64_KEY"
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "azureDefault": {
    "Token": "",
    "Org": "",
    "Project": "",
    "Repo": "",
    "Sandbox": ""

  },
  "Git": {
    "AzureDevOps": {
      "DomainPatterns": [
        "dev.azure.com",
        "visualstudio.com"
      ],
      "Username": "",
      "EnableUrlEncoding": true,
      "DefaultOrganization": "",
      "DefaultProject": ""
    },
    "Path": {
      "MaxPathLength": 260,
      "TempPathTemplate": "C:\\temp\\repo-{guid}",
      "AutoShortenPaths": true,
      "ShortPathIdLength": 3
    },
    "StringHandling": {
      "GitHubUsername": "x-access-token",
      "GitLabUsername": "oauth2",
      "SpecialCharacters": [
        " ",
        "@",
        "#",
        "$",
        "%",
        "^",
        "&",
        "*",
        "(",
        ")",
        "+",
        ",",
        ";",
        "=",
        "?",
        "/"
      ],
      "NormalizeWhitespace": true,
      "WhitespaceReplacement": "_"
    },
    "Providers": {
      "DefaultUsername": "git",
      "UseSshByDefault": false,
      "SshPort": 22,
      "ConnectionTimeoutSeconds": 60
    }
  }
}
